# FETCH — Ortam Değişkenleri
# Bu dosyayı kendi ayarlarınıza göre düzenleyin.

# Discord Bot Token (discord_bot.py için)
DISCORD_TOKEN=BURAYA_DISCORD_BOT_TOKEN

# FETCH sunucu adresi (bot için)
FETCH_URL=http://localhost:5000

# FETCH erişim şifresi (varsa)
FETCH_TOKEN=

# Flask ayarları
FLASK_PORT=5000
FLASK_DEBUG=false
